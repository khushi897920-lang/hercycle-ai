# HerCycle AI — Environment Variables Template
# Copy this file to .env.local and fill in the values.

# ------------------------------------------------------------
# 1. Supabase Database Configuration
# ------------------------------------------------------------
# Your Supabase Project API URL (found in Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key (used on the client-side browser, subject to RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key_here

# Service role key (bypasses RLS, used STRICTLY on the server-side Next.js routes)
# ⚠️ WARNING: Never expose this key in git, frontend files, or logs.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ------------------------------------------------------------
# 2. Clerk Authentication Configuration
# ------------------------------------------------------------
# Clerk publishable key (exposed on the browser to load user sessions)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here

# Clerk secret API key (server-only, verified by middleware and auth contexts)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_here

# Clerk Webhook Secret (used to verify incoming user.deleted webhooks from Clerk)
# Found in Clerk Dashboard -> Webhooks -> Add Endpoint -> Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_signing_secret_here

# ------------------------------------------------------------
# 3. AI Integrations
# ------------------------------------------------------------
# Google Gemini API key (for primary chat assistant queries)
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# Groq API key (for fallback Chat Assistant queries, optional)
GROQ_API_KEY=gsk_your_groq_key_here
